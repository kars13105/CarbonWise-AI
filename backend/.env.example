# CarbonWise AI Backend Environment Variables
# Copy this file to .env and fill in your values

# AI Provider API Keys (set ONE of these — Grok is checked first)
# Option 1: xAI Grok (recommended — faster)
XAI_API_KEY=your_xai_api_key_here
# Option 2: Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database URL (default: SQLite)
# For PostgreSQL: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./carbonwise.db
